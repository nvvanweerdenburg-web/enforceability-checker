# Copy to .env and fill in your API key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (adjust if you hit token limits on very long documents):
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=8192          # Increase if analysis gets truncated
# MAX_UPLOAD_BYTES=10485760          # 10 MB
# MAX_DOC_CHARS=120000               # 120 KB of text
